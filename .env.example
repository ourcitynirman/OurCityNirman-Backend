# ─────────────────────────────────────────────────────────────────
#  OurCityNirman Backend — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────
NODE_ENV=development           # development | production
PORT=5000

# ── Database ───────────────────────────────────────────────────────
# Local (development)
MONGODB_URI=mongodb://127.0.0.1:27017
# Production Atlas (uncomment and fill)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net

# ── JWT ────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=replace_with_64_char_random_hex
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace_with_64_char_random_hex
REFRESH_TOKEN_EXPIRY=30d
RESET_PASSWORD_SECRET=replace_with_64_char_random_hex

# ── CORS ───────────────────────────────────────────────────────────
# Local (development)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Production (uncomment and fill)
# CORS_ORIGIN=https://www.ourcitynirman.com,https://ourcitynirman.com
# FRONTEND_URL=https://www.ourcitynirman.com

# ── Cloudinary ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay ───────────────────────────────────────────────────────
# Use rzp_test_* for dev, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Email (Brevo / SMTP) ───────────────────────────────────────────
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM="Our City Nirman Pvt. Ltd. <noreply@ourcitynirman.com>"

# ── Optional: Twilio (SMS OTP) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
